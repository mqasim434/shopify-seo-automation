# Shopify — use your *.myshopify.com URL, NOT the custom storefront domain
SHOPIFY_STORE_URL=https://yourstore.myshopify.com
# From Dev Dashboard → your app → Settings
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=shpss_xxxx
# Same value as SHOPIFY_CLIENT_SECRET — used for webhook HMAC verification
SHOPIFY_WEBHOOK_SECRET=shpss_xxxx
# Permanent token — required for production stores (get via /auth/install OAuth flow)
SHOPIFY_ACCESS_TOKEN=
# OAuth callback URL — add this exact URL in Dev Dashboard → app → Settings → Allowed redirection URL(s)
# SHOPIFY_OAUTH_REDIRECT_URI=https://your-ngrok-url.ngrok-free.app/auth/callback

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxx

# Google Sheets
GOOGLE_SHEETS_ID=your_sheet_id
# Tab ID from sheet URL (?gid=123456) — recommended over tab name
GOOGLE_SHEETS_GID=48886204
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Server (optional)
PORT=3000
